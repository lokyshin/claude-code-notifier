# ============================================================
# Claude Code Notifier - 配置文件示例
# 复制为 ~/.claude/notifier.conf 并填入你的真实值
# ============================================================

# ── 飞书通知 ──
USE_FEISHU=1
FEISHU_MODE="app"                          # webhook 或 app
# webhook 模式
FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN"
# app 模式
FEISHU_APP_ID="YOUR_APP_ID"
FEISHU_APP_SECRET="YOUR_APP_SECRET"
FEISHU_RECEIVE_TYPE="open_id"              # open_id / chat_id / user_id
FEISHU_RECEIVE_ID="YOUR_RECEIVE_ID"

# ── Server酱（个人微信）──
USE_SERVERCHAN=0
SERVERCHAN_KEY="YOUR_SERVERCHAN_KEY"

# ── 企业微信机器人 ──
USE_WXWORK=0
WXWORK_WEBHOOK="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY"

# ── 远程审批服务 ──
USE_REMOTE_APPROVE=1
APPROVE_SERVER="https://your-domain.com"   # 审批服务公网地址
APPROVE_INTERVAL=3                         # 轮询间隔（秒）

# ── 审批过期时间（秒）──
# 同时控制：服务端请求存活时间 + 客户端轮询超时
# ⚠️ 安全提示：审批 API 无内置认证，任何能访问服务的人都可以批准请求。
#    值越短越安全。建议 120~300 秒，手机审批通常几十秒内完成。
#    如需对外暴露，强烈建议通过 Nginx 加 Basic Auth 或 mTLS。
APPROVE_EXPIRE=300                         # 默认 5 分钟（300秒）

# ── tmux（hook 子进程可能丢失 TMUX/TMUX_PANE，动态检测）──
# 当 Claude Code hook 以子进程执行 notify.sh 时，$TMUX 和 $TMUX_PANE
# 环境变量可能不会被继承，导致按键注入失败。以下代码自动检测并恢复。
# 此配置可直接复制到任何新服务器，无需修改。
if [ -z "$TMUX" ]; then
  _tmux_sock=$(find /tmp/tmux-$(id -u)/ -type s 2>/dev/null | head -1)
  if [ -n "$_tmux_sock" ]; then
    _tmux_pid=$(tmux -S "$_tmux_sock" display-message -p '#{pid}' 2>/dev/null)
    TMUX="${_tmux_sock},${_tmux_pid:-0},0"
    export TMUX
  fi
fi
if [ -z "$TARGET_PANE" ] && [ -z "$TMUX_PANE" ]; then
  TARGET_PANE=$(tmux list-panes -a -F '#{pane_id} #{pane_current_command}' 2>/dev/null \
    | grep -i 'claude\|node\|bun' | head -1 | awk '{print $1}')
  [ -z "$TARGET_PANE" ] && TARGET_PANE=$(tmux display-message -p '#{pane_id}' 2>/dev/null)
fi

# ── 日志 ──
LOG_FILE="$HOME/.claude/notifier.log"
