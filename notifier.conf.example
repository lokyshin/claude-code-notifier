# Claude Code Notifier - 配置文件
# 复制此文件到 ~/.claude/notifier.conf 并填入你的配置
# cp notifier.conf.example ~/.claude/notifier.conf

# ============================================================
# 飞书机器人
# 获取方式：飞书群 → 设置 → 群机器人 → 添加自定义机器人
# ============================================================
USE_FEISHU=0
FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN"

# ============================================================
# Server酱（微信推送）
# 获取方式：https://sct.ftqq.com 微信登录获取 SendKey
# ============================================================
USE_SERVERCHAN=0
SERVERCHAN_KEY="YOUR_SENDKEY"

# ============================================================
# 企业微信机器人
# 获取方式：企业微信群 → 右键 → 添加群机器人
# ============================================================
USE_WXWORK=0
WXWORK_WEBHOOK="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY"

# ============================================================
# 日志文件路径（可选）
# ============================================================
LOG_FILE="$HOME/.claude/notifier.log"