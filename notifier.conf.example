# ============================================================
# Claude Code Notifier - 配置文件模板
# 
# 使用方法：
#   cp notifier.conf.example ~/.claude/notifier.conf
#   nano ~/.claude/notifier.conf
# ============================================================


# ────────────────────────────────────────────────────────────
# 飞书通知
# ────────────────────────────────────────────────────────────
USE_FEISHU=1

# 选择飞书接入模式：
#
#   webhook  ← 企业版飞书推荐
#              群机器人直接获取 Webhook URL，永久有效，配置最简单
#
#   app      ← 个人版飞书推荐
#              用 App ID + Secret 自动刷新 Token（2小时自动续期）
#
FEISHU_MODE="webhook"


# ── 模式一：webhook ──────────────────────────────────────────
# 获取方式：
#   飞书群 → 设置 → 群机器人 → 添加机器人 → 自定义机器人 → 复制 Webhook
#
# 详细教程：docs/feishu.md
#
FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN"


# ── 模式二：app ──────────────────────────────────────────────
# 获取方式：
#   1. 访问 https://open.feishu.cn/app
#   2. 创建「企业自建应用」
#   3. 凭证与基础信息页面获取 App ID 和 App Secret
#   4. 权限管理开通：im:message:send_as_bot
#   5. 发布应用
#
# 详细教程：docs/feishu.md
#
FEISHU_APP_ID="cli_xxxxxxxxxxxxxxxx"
FEISHU_APP_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 推送目标：
#   chat_id  → 推送到群（格式：oc_xxxxxxxxx）
#   open_id  → 推送给个人（格式：ou_xxxxxxxxx）
FEISHU_RECEIVE_TYPE="chat_id"
FEISHU_RECEIVE_ID="oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"


# ────────────────────────────────────────────────────────────
# Server酱（个人微信推送）
# ────────────────────────────────────────────────────────────
# 获取方式：
#   1. 访问 https://sct.ftqq.com
#   2. 微信扫码登录
#   3. 复制 SendKey
#   4. 微信关注「方糖」公众号
#
# 详细教程：docs/serverchan.md
#
USE_SERVERCHAN=0
SERVERCHAN_KEY="YOUR_SENDKEY"


# ────────────────────────────────────────────────────────────
# 企业微信机器人
# ────────────────────────────────────────────────────────────
# 获取方式：
#   企业微信群 → 右键群名 → 添加群机器人 → 新建机器人 → 复制 Webhook
#
# 详细教程：docs/wxwork.md
#
USE_WXWORK=0
WXWORK_WEBHOOK="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY"


# ────────────────────────────────────────────────────────────
# 日志
# ────────────────────────────────────────────────────────────
LOG_FILE="$HOME/.claude/notifier.log"